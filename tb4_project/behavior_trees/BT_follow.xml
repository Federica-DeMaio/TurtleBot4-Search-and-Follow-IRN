<!--
  Follow Behavior Tree for tb4_project.

  Initial version copied from BT_search.xml. It will be adapted for ArUco
  following while keeping Nav2 responsible for planning, path following, and
  navigation recoveries for the current follow goal.
-->
<root main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <RecoveryNode number_of_retries="6" name="NavigateRecovery">
      <PipelineSequence name="NavigateWithReplanning">
        <RateController hz="1.0">
          <RecoveryNode number_of_retries="1" name="ComputePathToPose">
            <ComputePathToPose goal="{goal}" path="{path}" planner_id="GridBased"/>
            <Sequence name="ComputePathRecovery">
              <ClearEntireCostmap name="ClearGlobalCostmap-Context" service_name="global_costmap/clear_entirely_global_costmap"/>
              <Wait name="WaitAfterGlobalClear" wait_duration="0.5"/>
            </Sequence>
          </RecoveryNode>
        </RateController>
        <RecoveryNode number_of_retries="2" name="FollowPath">
          <ReactiveSequence name="FollowPathUnlessStuck">
            <Inverter>
              <IsStuck/>
            </Inverter>
            <FollowPath path="{path}" controller_id="FollowPath"/>
          </ReactiveSequence>
          <Sequence name="FollowPathRecovery">
            <ClearEntireCostmap name="ClearLocalCostmapBeforeSpin" service_name="local_costmap/clear_entirely_local_costmap"/>
            <Wait name="WaitAfterLocalClear" wait_duration="0.5"/>
            <Spin name="SpinAfterFollowPathFailure" spin_dist="3.14"/>
            <DriveOnHeading name="DriveForwardAfterFollowPathSpin" dist_to_travel="0.15" speed="0.05" time_allowance="8"/>
          </Sequence>
        </RecoveryNode>
      </PipelineSequence>
      <ReactiveFallback name="RecoveryFallback">
        <GoalUpdated/>
        <RoundRobin name="RecoveryActions">
          <Sequence name="ClearingActionsBeforeMotion">
            <ClearEntireCostmap name="ClearLocalCostmap-Subtree" service_name="local_costmap/clear_entirely_local_costmap"/>
            <ClearEntireCostmap name="ClearGlobalCostmap-Subtree" service_name="global_costmap/clear_entirely_global_costmap"/>
          </Sequence>
          <Sequence name="SpinAndDriveGlobalRecovery">
            <Spin name="SpinGlobalRecovery" spin_dist="3.14"/>
            <DriveOnHeading name="DriveForwardAfterGlobalSpin" dist_to_travel="0.15" speed="0.05" time_allowance="8"/>
          </Sequence>
        </RoundRobin>
      </ReactiveFallback>
    </RecoveryNode>
  </BehaviorTree>
</root>
